  <MdxScripts>
    <MdxScript dwd:design-time-name="cac7fc7d-f7d0-4eca-ae26-92caa45d41dd">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE DYNAMIC SET CURRENTCUBE.[cau14]
 AS FILTER(
            [DIM DATE].[Year].MEMBERS,
            [Measures].[Loan Amount Requested] = MAX(
                [DIM DATE].[Year].MEMBERS,
                [Measures].[Loan Amount Requested]
            )) ; 
CREATE DYNAMIC SET CURRENTCUBE.[Cau15]
 AS INTERSECT(
    TOPPERCENT(
        [DIM LOCATION].[STATE].MEMBERS,
        60,
        [Measures].[FACT Count]
    ),
    TOPPERCENT(
        [DIM LOCATION].[STATE].MEMBERS,
        60,
        [Measures].[Loan Amount Requested]
    )
) ;      
CREATE DYNAMIC SET CURRENTCUBE.[Cau12]
 AS BOTTOMCOUNT(
        [DIM LOCATION].[STATE].MEMBERS,
        5,
        [Measures].[FACT Count]
    );     
CREATE DYNAMIC SET CURRENTCUBE.[Cau13]
 AS EXCEPT(
    [DIM LOANPURPOSE].[PURPOSE NAME].MEMBERS,
    FILTER(
        [DIM LOANPURPOSE].[PURPOSE NAME].MEMBERS,
        [Measures].[FACT Count] &lt; 500
    )
);        
CREATE DYNAMIC SET CURRENTCUBE.[CAU11]
 AS SUBSET(
    ORDER(
        [DIM DATE].[Year].MEMBERS,
        [Measures].[FACT Count],
        DESC
    ),
    (COUNT([DIM DATE].[Year].MEMBERS) / 2) - 1,
    3
); </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>